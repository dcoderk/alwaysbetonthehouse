{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "color": {
      "defaultPalette": false,
      "defaultGradients": false,
      "palette": [
        { "slug": "base", "name": "Base", "color": "#ffffff" },
        { "slug": "contrast", "name": "Contrast", "color": "#111111" },
        { "slug": "primary", "name": "Primary", "color": "#2563eb" },
        { "slug": "secondary", "name": "Secondary", "color": "#0f172a" },
        { "slug": "muted", "name": "Muted", "color": "#f1f5f9" },
        { "slug": "accent", "name": "Accent", "color": "#f59e0b" }
      ]
    },
    "spacing": {
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      },
      "units": ["px", "rem", "%", "vw", "vh"]
    },
    "typography": {
      "defaultFontSizes": false,
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
          "name": "System Sans",
          "slug": "system-sans"
        },
        {
          "fontFamily": "Georgia, serif",
          "name": "Serif",
          "slug": "serif"
        }
      ],
      "fontSizes": [
        { "slug": "sm", "size": "0.875rem", "name": "Small" },
        { "slug": "md", "size": "1rem", "name": "Medium" },
        { "slug": "lg", "size": "1.25rem", "name": "Large" },
        { "slug": "xl", "size": "2rem", "name": "XL" },
        { "slug": "xxl", "size": "3rem", "name": "2XL" }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "radius": true
        }
      },
      "core/heading": {
        "typography": {
          "lineHeight": true
        }
      },
      "core/navigation": {
        "typography": {
          "fontSize": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-sans)",
      "fontSize": "var(--wp--preset--font-size--md)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "elements": {
      "heading": {
        "typography": {
          "lineHeight": "1.2",
          "fontWeight": "700"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          }
        }
      },
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "top": "0.85rem",
            "bottom": "0.85rem",
            "left": "1.25rem",
            "right": "1.25rem"
          }
        },
        "typography": {
          "fontWeight": "600"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/post-title": {
        "typography": {
          "fontWeight": "700"
        }
      },
      "core/group": {
        "spacing": {
          "padding": {
            "top": "0",
            "bottom": "0",
            "left": "0",
            "right": "0"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "customTemplates": [
    {
      "name": "landing",
      "title": "Landing Page",
      "postTypes": ["page"]
    }
  ]
}
